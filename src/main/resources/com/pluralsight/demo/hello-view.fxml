<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>

<VBox spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pluralsight.demo.HelloController"
      styleClass="root-container">

    <!-- Header Bar -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="16" bottom="16" left="28" right="28"/></padding>
        <Label text="" styleClass="header-icon"/>
        <Label text="Da best theater" styleClass="header-title"/>
        <Label text="Reservation Kiosk" styleClass="header-subtitle"/>
    </HBox>

    <Separator/>

    <!-- Main Content -->
    <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets top="40" bottom="40" left="200" right="200"/></padding>

        <Label text="NEW RESERVATION" styleClass="section-label"/>
        <Label text="Enter guest details below to complete booking"
               styleClass="section-hint"/>

        <Separator style="-fx-padding: 4 0;"/>

        <Label text="Guest Name" styleClass="field-label"/>
        <TextField fx:id="nameInput" promptText="First and Last Name"
                   styleClass="pos-field"/>

        <Label text="Reservation Date" styleClass="field-label"/>
        <TextField fx:id="DateInput" promptText="MM/DD/YYYY"
                   styleClass="pos-field"/>

        <Label text="Number of Tickets" styleClass="field-label"/>
        <TextField fx:id="TicketNumInput" promptText="e.g. 2"
                   styleClass="pos-field"/>

        <Separator style="-fx-padding: 4 0;"/>

        <Label fx:id="welcomeText" styleClass="confirmation-text"/>

        <Button text="CONFIRM RESERVATION" onAction="#onInputSubmit"
                styleClass="pos-button" maxWidth="Infinity"/>
    </VBox>

    <!-- Footer -->
    <HBox styleClass="footer-bar" alignment="CENTER">
        <padding><Insets top="12" bottom="12"/></padding>
        <Label text="CineCore POS v1.0  •  Terminal 01  •  Staff Mode"
               styleClass="footer-text"/>
    </HBox>

</VBox>